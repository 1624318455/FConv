{
  "name": "fconv-desktop",
  "version": "1.0.0",
  "description": "FConv 智能文档文字提取器 - 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "devDependencies": {
    "electron": "33.0.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "collectCoverageFrom": ["*.js", "!node_modules/**", "!__tests__/**"],
    "coverageDirectory": "coverage",
    "verbose": true
  },
  "build": {
    "appId": "com.fconv.extractor",
    "productName": "FConv",
    "directories": {
      "output": "dist"
    },
    "files": [
      "*.html",
      "*.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable"
    }
  }
}
