{
  "name": "fconv-desktop",
  "version": "1.0.0",
  "description": "FConv 智能文档文字提取器 - 桌面版",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "33.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.fconv.extractor",
    "productName": "FConv",
    "directories": {
      "output": "dist"
    },
    "files": [
      "*.html",
      "*.js",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable"
    }
  }
}
